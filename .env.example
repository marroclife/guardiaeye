# =====================================================
# NEXO's Eye — Environment Variables
# =====================================================
# IMPORTANTE: copie este arquivo para .env e preencha
# com as credenciais do projeto Supabase DEDICADO do
# NEXO's Eye (criar novo projeto em supabase.com/dashboard)
#
# Por enquanto, o .env atual aponta para um Supabase que
# hospeda o TimeTemple. NÃO é o backend do NEXO's Eye.
# =====================================================

# Projeto Supabase dedicado do NEXO's Eye
# Criar em: https://supabase.com/dashboard → New Project
# Nome sugerido: "nexos-eye-prod" (ou nexos-eye-dev)
VITE_SUPABASE_URL="https://SEU-PROJECT-ID.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="SUA-CHAVE-PUBLISHABLE-ANON"

# Project ID (apenas referência, não usado em runtime)
VITE_SUPABASE_PROJECT_ID="SEU-PROJECT-ID"

# =====================================================
# Schema SQL para criar ao provisionar (rodar no SQL Editor):
# =====================================================
#
-- Tabela principal de leads capturados pela landing
-- create table public.leads_eye (
--   id uuid primary key default gen_random_uuid(),
--   name text not null,
--   city text not null,
--   nicho text not null check (nicho in ('restaurante','servico','varejo','outro')),
--   arquetipo text not null,
--   status text not null default 'minerado'
--     check (status in ('minerado','abordado','aquecido','quente','frio')),
--   whatsapp_sent boolean not null default false,
--   source text default 'eye.marroc.xyz',
--   utm_source text,
--   utm_campaign text,
--   created_at timestamp with time zone default now(),
--   updated_at timestamp with time zone default now()
-- );
--
-- -- RLS: leitura/escrita apenas via service role (backend)
-- -- A landing não persiste ainda (v1 sem banco).
-- -- Quando ativar, habilitar RLS e criar policies.
--
-- -- Auth: criar primeiro usuário admin via Sign Up na própria tela /auth
